generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  password              String
  role                  String    @default("CLIENT")
  status                String    @default("ACTIVE")
  createdByAdmin        Boolean   @default(false)
  zipCode               String?
  addressStreet         String?
  addressNumber         String?
  addressNeighborhood   String?
  addressCity           String?
  addressState          String?
  addressComplement     String?
  addressCountry        String?
  addressNotes          String?
  plan                  String    @default("FREE")
  planStatus            String    @default("ACTIVE")
  planActivatedAt       DateTime?
  billingProvider       String?
  billingPendingPlan    String?
  billingCustomerId     String?   @unique
  billingSubscriptionId String?   @unique
  billingCheckoutId     String?   @unique
  headline              String?
  bio                   String?
  city                  String?
  state                 String?
  specialties           String?
  experienceYears       Int?
  availabilityNotes     String?
  websiteUrl            String?
  instagramHandle       String?
  companyId             String?
  company               Company?  @relation(fields: [companyId], references: [id])
  emailVerifiedAt       DateTime?
  phone                 String?
  phoneVerifiedAt       DateTime?
  twoFactorEnabled      Boolean   @default(false)
  breedAdvisorProfile   Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  dogs                  Dog[]
  modules               Module[]              @relation("UserModules")
  schedules             Schedule[]
  assignedSchedules     Schedule[]            @relation("ScheduleTrainer")
  blogPosts             BlogPost[]
  blogComments          BlogComment[]         @relation("UserBlogComments")
  blogReactions         BlogPostReaction[]
  forumChannels         ForumChannel[]        @relation("ForumChannelOwner")
  channelSubscriptions  ChannelSubscription[]
  channelContents       ChannelContent[]      @relation("ChannelContentAuthor")
  forumThreads          ForumThread[]         @relation("UserForumThreads")
  forumThreadReactions  ForumThreadReaction[]
  forumReplies          ForumReply[]          @relation("UserForumReplies")
  coachedTrainings      TrainingSession[]     @relation("TrainingSessionCoach")
  adminCreatedDogs      Dog[]                 @relation("DogCreatedByAdmin")
  adminCreatedSchedules Schedule[]            @relation("ScheduleCreatedByAdmin")
  adminCreatedTrainings TrainingSession[]     @relation("TrainingSessionCreatedByAdmin")
  trainingConfirmations TrainingSession[]     @relation("TrainingSessionConfirmedBy")
  notifications         Notification[]
  payments              Payment[]
  auditLogs             AuditLog[]
  verificationCodes     VerificationCode[]
  forumPosts            ForumPost[]           @relation("UserForumPosts")
}

model Module {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  contentIds  String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserModules")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  dogs      Dog[]
}

model Dog {
  id                         String            @id @default(cuid())
  name                       String
  breed                      String
  photoUrl                   String?
  breedApiId                 String?
  breedGroup                 String?
  breedOrigin                String?
  breedTemperament           String?
  breedDescription           String?
  breedLifeSpan              String?
  breedWeightMinKg           Float?
  breedWeightMaxKg           Float?
  breedHeightReferenceCm     String?
  breedReferenceImageUrl     String?
  age                        Int
  size                       String?
  weightKg                   Float?
  gender                     String?
  color                      String?
  birthDate                  DateTime?
  foodName                   String?
  mealsPerDay                Int?
  portionSize                String?
  feedingTimes               String?
  allergies                  String?
  medications                String?
  healthNotes                String?
  behaviorNotes              String?
  energyLevel                String?
  activityProfile            String            @default("COMPANION")
  sportFocus                 String?
  dailyExerciseGoalMinutes   Int?
  weeklyConditioningSessions Int?
  bodyConditionScore         Int?
  restingHeartRateBpm        Int?
  athleteClearance           Boolean           @default(false)
  lastVetCheckupAt           DateTime?
  hydrationPlan              String?
  supplements                String?
  injuryHistory              String?
  veterinaryRestrictions     String?
  recoveryNotes              String?
  performanceGoals           String?
  vaccinated                 Boolean           @default(false)
  neutered                   Boolean           @default(false)
  ownerId                    String
  owner                      User              @relation(fields: [ownerId], references: [id])
  createdByAdminId           String?
  createdByAdmin             User?             @relation("DogCreatedByAdmin", fields: [createdByAdminId], references: [id])
  companyId                  String?
  company                    Company?          @relation(fields: [companyId], references: [id])
  schedules                  Schedule[]
  trainings                  TrainingSession[]
  createdAt                  DateTime          @default(now())
}

model TrainingSession {
  id               String   @id @default(cuid())
  title            String
  description      String?
  focusArea        String?
  difficulty       String?
  durationMinutes  Int?
  trainerNotes     String?
  homework         String?
  videoUrl         String?
  confirmationNote String?
  confirmationMediaUrl String?
  confirmedAt      DateTime?
  confirmedByUserId String?
  confirmedByUser  User?    @relation("TrainingSessionConfirmedBy", fields: [confirmedByUserId], references: [id])
  progress         Int
  dogId            String
  dog              Dog      @relation(fields: [dogId], references: [id])
  coachId          String?
  coach            User?    @relation("TrainingSessionCoach", fields: [coachId], references: [id])
  createdByAdminId String?
  createdByAdmin   User?    @relation("TrainingSessionCreatedByAdmin", fields: [createdByAdminId], references: [id])
  executedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
}

model Schedule {
  id               String   @id @default(cuid())
  title            String   @default("Sessao de treino")
  notes            String?
  location         String?
  format           String   @default("PRESENTIAL")
  durationMinutes  Int?
  date             DateTime
  status           String
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  trainerId        String?
  trainer          User?    @relation("ScheduleTrainer", fields: [trainerId], references: [id])
  createdByAdminId String?
  createdByAdmin   User?    @relation("ScheduleCreatedByAdmin", fields: [createdByAdminId], references: [id])
  dogId            String?
  dog              Dog?     @relation(fields: [dogId], references: [id])
}

model BlogPost {
  id            String             @id @default(cuid())
  title         String
  slug          String             @unique
  category      String             @default("GERAL")
  postType      String             @default("POST")
  accessLevel   String             @default("FREE")
  excerpt       String?
  content       String
  coverImageUrl String?
  videoUrl      String?
  featured      Boolean            @default(false)
  eventStartsAt DateTime?
  eventEndsAt   DateTime?
  eventLocation String?
  eventCity     String?
  eventState    String?
  published     Boolean            @default(true)
  authorId      String
  author        User               @relation(fields: [authorId], references: [id])
  comments      BlogComment[]
  reactions     BlogPostReaction[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Payment {
  id                     String   @id @default(cuid())
  stripeEventId          String?  @unique
  provider               String   @default("STRIPE")
  providerEventId        String?  @unique
  providerCheckoutId     String?
  providerSubscriptionId String?
  providerPaymentId      String?
  type                   String
  status                 String?
  amount                 Int?
  currency               String?
  customerEmail          String?
  customerId             String?
  userId                 String?
  user                   User?    @relation(fields: [userId], references: [id])
  raw                    String?
  createdAt              DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  link      String?
  readAt    DateTime?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ForumChannel {
  id                String                @id @default(cuid())
  slug              String                @unique
  name              String
  description       String
  category          String                @default("COMUNIDADE")
  serviceMode       String                @default("COMMUNITY")
  subscriptionPrice Int?
  onlinePrice       Int?
  inPersonPrice     Int?
  city              String?
  state             String?
  acceptsRemote     Boolean               @default(false)
  isPublic          Boolean               @default(true)
  featured          Boolean               @default(false)
  ownerId           String
  owner             User                  @relation("ForumChannelOwner", fields: [ownerId], references: [id])
  subscriptions     ChannelSubscription[]
  contents          ChannelContent[]
  threads           ForumThread[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model ChannelSubscription {
  id        String       @id @default(cuid())
  status    String       @default("ACTIVE")
  tier      String       @default("FREE")
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  channelId String
  channel   ForumChannel @relation(fields: [channelId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
}

model ChannelContent {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  summary         String?
  body            String
  coverImageUrl   String?
  category        String       @default("TREINO")
  contentType     String       @default("LESSON")
  accessLevel     String       @default("SUBSCRIBER")
  objective       String?
  difficulty      String?
  durationMinutes Int?
  orderIndex      Int?
  videoUrl        String?
  published       Boolean      @default(true)
  authorId        String
  author          User         @relation("ChannelContentAuthor", fields: [authorId], references: [id])
  channelId       String
  channel         ForumChannel @relation(fields: [channelId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ForumPost {
  id        String      @id @default(cuid())
  content   String
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  authorId  String
  author    User        @relation("UserForumPosts", fields: [authorId], references: [id])
  createdAt DateTime    @default(now())
}

model ForumThread {
  id            String                @id @default(cuid())
  title         String
  content       String
  postType      String                @default("POST")
  imageUrl      String?
  videoUrl      String?
  eventStartsAt DateTime?
  eventEndsAt   DateTime?
  eventLocation String?
  eventCity     String?
  eventState    String?
  channelId     String?
  channel       ForumChannel?         @relation(fields: [channelId], references: [id])
  isPinned      Boolean               @default(false)
  authorId      String
  author        User                  @relation("UserForumThreads", fields: [authorId], references: [id])
  replies       ForumReply[]
  reactions     ForumThreadReaction[]
  posts         ForumPost[] // <-- ADICIONE ESTA LINHA
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model ForumReply {
  id        String      @id @default(cuid())
  content   String
  authorId  String
  author    User        @relation("UserForumReplies", fields: [authorId], references: [id])
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  createdAt DateTime    @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BlogComment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation("UserBlogComments", fields: [authorId], references: [id])
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model BlogPostReaction {
  id        String   @id @default(cuid())
  type      String   @default("LIKE")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model ForumThreadReaction {
  id        String      @id @default(cuid())
  type      String      @default("LIKE")
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([threadId, userId])
}
